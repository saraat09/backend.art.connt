APP_NAME=ArtisanConnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Casablanca
APP_LOCALE=fr

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Base de données MySQL ─────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artisan_connect
DB_USERNAME=root
DB_PASSWORD=

# ── JWT ──────────────────────────────────────
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# ── Cache / Sessions ─────────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ── Broadcast (Pusher pour temps réel) ───────
BROADCAST_DRIVER=log

PUSHER_APP_ID=dummy
PUSHER_APP_KEY=dummy
PUSHER_APP_SECRET=dummy
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# ── Filesystem ────────────────────────────────
FILESYSTEM_DISK=local

# ── CORS / Frontend origins ───────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_SUPPORTS_CREDENTIALS=false

# ── Stripe (paiements) ────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Mail (optionnel) ─────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@artisanconnect.ma
MAIL_FROM_NAME="${APP_NAME}"
